{
  "name": "personal-plugins",
  "owner": {
    "name": "Sallvainian",
    "url": "https://github.com/Sallvainian"
  },
  "metadata": {
    "description": "MCP servers for the My Love PWA project",
    "version": "1.0.0"
  },
  "plugins": [
    {
      "name": "my-love-plugins",
      "source": "./plugins/my-love-plugins",
      "description": "MCP servers for development: Playwright, TypeScript docs, Supabase, Vitest, and Refactor TypeScript",
      "version": "1.0.0",
      "author": {
        "name": "Sallvainian"
      },
      "keywords": ["mcp", "playwright", "supabase", "vitest", "typescript"],
      "strict": false,
      "mcpServers": {
        "playwright": {
          "command": "npx",
          "args": ["@playwright/mcp@latest"]
        },
        "typescript-docs": {
          "command": "npx",
          "args": ["-y", "mcp-remote", "https://gitmcp.io/microsoft/TypeScript"],
          "url": "https://gitmcp.io/microsoft/TypeScript"
        },
        "supabase": {
          "type": "http",
          "url": "https://mcp.supabase.com/mcp"
        },
        "vitest": {
          "command": "npx",
          "args": ["-y", "@djankies/vitest-mcp"]
        },
        "refactor-typescript": {
          "command": "bunx",
          "args": ["mcp-refactor-typescript"]
        }
      }
    },
    {
      "name": "everything-claude-code",
      "source": "./plugins/everything-claude-code",
      "description": "Aside Command, Build and Fix, Code Review, evolve, /learn - Extract Reusable Patterns, /learn-eval - Extract, Evaluate, then Save, code-reviewer, architect, refactor-cleaner, typescript-reviewer, backend-patterns, Hooks Config",
      "version": "1.0.0",
      "author": {
        "name": "Affaan Mustafa"
      },
      "keywords": ["claude-code", "code-review", "refactor", "typescript", "architect"],
      "strict": false,
      "commands": [
        "./commands/aside.md",
        "./commands/build-fix.md",
        "./commands/code-review.md",
        "./commands/evolve.md",
        "./commands/learn.md",
        "./commands/learn-eval.md"
      ],
      "agents": [
        "./agents/code-reviewer.md",
        "./agents/architect.md",
        "./agents/refactor-cleaner.md",
        "./agents/typescript-reviewer.md"
      ],
      "skills": [
        "./skills/backend-patterns/SKILL.md"
      ],
      "hooks": "./hooks/hooks.json"
    }
  ]
}
